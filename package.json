{
  "name": "bau-os",
  "version": "0.1.0",
  "description": "KI-Plattform fuer Bauunternehmen",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "setup": "tsx scripts/setup.ts",
    "fresh": "tsx scripts/fresh.ts",
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "build:all": "tsc && vite build --config web/vite.config.ts",
    "dev:web": "vite dev --config web/vite.config.ts",
    "start": "node dist/index.js",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/ tests/",
    "lint:fix": "eslint src/ tests/ --fix",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"tests/**/*.ts\"",
    "prepare": "husky"
  },
  "author": "Julius Sima",
  "license": "MIT",
  "dependencies": {
    "@hono/node-server": "^1.19.13",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@types/node": "^25.5.2",
    "@types/node-cron": "^3.0.11",
    "bcrypt": "^6.0.0",
    "dotenv": "^17.4.0",
    "grammy": "^1.42.0",
    "hono": "^4.12.12",
    "jsonwebtoken": "^9.0.3",
    "node-cron": "^4.2.1",
    "openai": "^6.33.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tailwindcss/vite": "^4.2.2",
    "@types/bcrypt": "^6.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@vitejs/plugin-vue": "^6.0.5",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "marked": "^18.0.0",
    "pinia": "^3.0.4",
    "prettier": "^3.8.2",
    "tailwindcss": "^4.2.2",
    "typescript-eslint": "^8.58.1",
    "vite": "^5.4.21",
    "vitepress": "^1.6.4",
    "vitest": "^4.1.4",
    "vue": "^3.5.32",
    "vue-router": "^5.0.4"
  },
  "lint-staged": {
    "src/**/*.ts": [
      "prettier --write",
      "eslint --fix --no-warn-ignored"
    ],
    "tests/**/*.ts": [
      "prettier --write",
      "eslint --fix --no-warn-ignored"
    ]
  }
}
