# Bau-OS Konfiguration
# Kopiere diese Datei nach .env und fülle die Werte aus:
#   cp .env.example .env
# Oder führe den interaktiven Installer aus:
#   npm run setup

# ── Pflichtfelder ─────────────────────────────────────────────────────────────

# Telegram Bot Token (von @BotFather → /newbot)
BOT_TOKEN=

# Pfad zum Workspace (wo Notizen, Aufgaben, Agenten gespeichert werden)
# Linux Beispiel:   /home/bauos/workspace
# Windows Beispiel: C:\Users\Julius\BauOS
WORKSPACE_PATH=

# ── LLM: Option A – OpenAI (empfohlen) ───────────────────────────────────────

# OpenAI API Key → automatisch gpt-4o-mini als Standard, gpt-4o für Vision
# Wenn gesetzt, wird Ollama ignoriert.
# OPENAI_API_KEY=sk-...

# Modell überschreiben (optional, Standard: gpt-4o-mini)
# OLLAMA_MODEL=gpt-4o-mini

# Vision-Modell für Fotos/Bilder (optional, Standard: gpt-4o)
# VISION_MODEL=gpt-4o

# ── LLM: Option B – Ollama lokal ─────────────────────────────────────────────

# Ollama API URL (Standard wenn Ollama lokal läuft)
OLLAMA_BASE_URL=http://localhost:11434/v1

# Hauptmodell für den Agenten
# Lokal:  qwen2.5:7b       (braucht ~4.3 GB RAM, vorher: ollama pull qwen2.5:7b)
# Cloud:  kimi-k2.5:cloud  (kein lokaler RAM nötig, einmalig: ollama signin)
OLLAMA_MODEL=kimi-k2.5:cloud

# Modell für /fast Modus (optional, Standard = OLLAMA_MODEL)
# OLLAMA_FAST_MODEL=qwen2.5:7b

# Modell für Sub-Agenten (optional, Standard = OLLAMA_MODEL)
# OLLAMA_SUBAGENT_MODEL=qwen2.5:7b

# ── Web-Oberfläche (Vault-Editor) ─────────────────────────────────────────────

# JWT Secret für Web-Login (generiere mit: openssl rand -hex 32)
# Wenn gesetzt, wird die Web-Oberfläche auf API_PORT gestartet
JWT_SECRET=

# Port für die Web-Oberfläche (Standard: 3000)
API_PORT=3000

# ── Datenbank (Supabase / PostgreSQL) ─────────────────────────────────────────

# PostgreSQL Connection String (aktiviert DB-Modus wenn gesetzt)
# Setup: bash scripts/setup-supabase.sh
# DATABASE_URL=postgres://postgres:DEIN_PASSWORT@localhost:5432/postgres

# Supabase Client (fuer Realtime, Storage, Auth)
# Wird von setup-supabase.sh ausgegeben
# SUPABASE_URL=http://localhost:8000
# SUPABASE_ANON_KEY=
# SUPABASE_SERVICE_KEY=

# ── Embeddings ────────────────────────────────────────────────────────────────

# Embedding-Modell (Standard: text-embedding-3-small bei OpenAI, nomic-embed-text bei Ollama)
# EMBEDDING_MODEL=text-embedding-3-small
# EMBEDDING_DIMENSIONS=1536

# ── Obsidian-Ordner ───────────────────────────────────────────────────────────

# Unterordner im Vault für Daily Notes (Standard: Daily)
# DAILY_NOTES_DIR=Daily

# Unterordner für Templates (Standard: Templates)
# TEMPLATES_DIR=Templates

# Unterordner für Anhänge/Uploads (Standard: Attachments)
# ATTACHMENTS_DIR=Attachments
