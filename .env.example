# Bau-OS Konfiguration
# Kopiere diese Datei nach .env und fülle die Werte aus:
#   cp .env.example .env
# Oder führe den interaktiven Installer aus:
#   npm run setup

# ── Pflichtfelder ─────────────────────────────────────────────────────────────

# Telegram Bot Token (von @BotFather → /newbot)
BOT_TOKEN=

# Pfad zum Obsidian Vault (wo Notizen, Aufgaben, Agenten gespeichert werden)
# Linux Beispiel:   /home/bauos/vault
# Windows Beispiel: C:\Users\Julius\Obsidian\BauOS
VAULT_PATH=

# ── LLM / Ollama ──────────────────────────────────────────────────────────────

# Ollama API URL (Standard wenn Ollama lokal läuft)
OLLAMA_BASE_URL=http://localhost:11434/v1

# Hauptmodell für den Agenten
# Lokal:  qwen2.5:7b       (braucht ~4.3 GB RAM, vorher: ollama pull qwen2.5:7b)
# Cloud:  kimi-k2.5:cloud  (kein lokaler RAM nötig, einmalig: ollama signin)
OLLAMA_MODEL=kimi-k2.5:cloud

# Modell für /fast Modus (optional, Standard = OLLAMA_MODEL)
# OLLAMA_FAST_MODEL=qwen2.5:7b

# Modell für Sub-Agenten (optional, Standard = OLLAMA_MODEL)
# OLLAMA_SUBAGENT_MODEL=qwen2.5:7b
