# ============================================================
# Bau-OS Docker — Umgebungsvariablen
# Kopiere nach docker/.env und fuelle aus:
#   cp docker/.env.example docker/.env
# ============================================================

# ── PostgreSQL ────────────────────────────────────────────────
POSTGRES_DB=bauos
POSTGRES_USER=bauos
POSTGRES_PASSWORD=                # Generiere: openssl rand -hex 24
POSTGRES_PORT=5432

# ── Supabase Studio ──────────────────────────────────────────
STUDIO_PORT=3001                  # Web-UI fuer DB-Management

# ── Supabase Realtime ─────────────────────────────────────────
REALTIME_PORT=4000
REALTIME_JWT_SECRET=              # Generiere: openssl rand -hex 32
REALTIME_ENC_KEY=                 # Generiere: openssl rand -hex 16
SECRET_KEY_BASE=                  # Generiere: openssl rand -base64 48
